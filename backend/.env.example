# Copy this file to .env and edit as needed.
# The app runs with ZERO of these set - defaults below give you the demo.

# --- Mode ---
# true  = simulated x402 payments, no blockchain keys needed (default, recommended for first run)
# false = real payments on Base Sepolia testnet (see docs/SETUP.md "Going live")
DEMO_MODE=true

PORT=4000

# --- Only required when DEMO_MODE=false ---
CHAIN_NETWORK=base-sepolia
BASE_RPC_URL=
WALLET_PRIVATE_KEY=
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_FACILITATOR_URL=https://x402.org/facilitator
LEDGER_CONTRACT_ADDRESS=

# --- Provider pricing (USD, charged in USDC) ---
PRICE_FX=$0.003
PRICE_CUSTOMS=$0.006
PRICE_LOGISTICS=$0.004
PROVIDER_PAY_TO=0x9F1c1B9A5b2E9B0e3c8A1d2F4E5D6C7B8A9F0E1D

# --- Optional: upgrade intent parsing from rules to an LLM call ---
ANTHROPIC_API_KEY=

# --- Mock mobile money off-ramp ---
MOMO_PROVIDER=mpesa
MOMO_SHORTCODE=174379
